{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Skynet++ Scripting Language",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#literals"
		},
		{
			"include": "#comments"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.spp",
				"match": "\\b(if|while|for|return|else|end|select|case|break|continue|def|func|include)\\b"
			},
			{
				"name": "keyword.operator.logical.spp",
				"match": "\\b(and|not|or)\\b"
			},
			{
				"name": "constant.language.bool.spp",
				"match": "\\b(true|false)\\b"
			},
			{
				"name": "keyword.operator.comparison.spp",
				"match": "(<=|>=|==|!=|=|>|<)"
			},
			{
				"name": "keyword.operator.arithmetic.spp",
				"match": "(?i)\\b(\\+|\\-|\\*|/)\\b"
			},
			{
				"name": "storage.modifier.spp",
				"match": "(?i)\\b(const|global|local|static|public|var)\\b"
			},
			{
				"name": "entity.name.function.spp",
				"match": "(?i)(?<=def\\s)\\w+\\s*(?=\\()"
			}
		]
		},
		"literals": {
			"patterns": [
				{
					"name": "string.quoted.double.spp",
					"begin": "\"",
					"end": "(\"|$)"
				},
				{
					"name": "constant.numeric.spp",
					"match": "\\b[0-9]+\\b"
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.spp",
					"begin": "/\\*",
					"end": "\\*/",
					"captures": {
						"0": { "name": "punctuation.definition.comment.spp" }
					}
				},
				{
					"name": "comment.line.double-slash.spp",
					"match": "(//).*$",
					"captures": {
						"1": { "name": "punctuation.definition.comment.spp" }
					}
				}
			]
		}
	},
	"scopeName": "source.spp"
}